# ============================================================
# CashView — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------ Supabase (frontend — safe to expose) ---------------
# Found at: supabase.com → your project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ------ Supabase Edge Function Secrets ---------------------
# Set these via: supabase secrets set KEY=value
# (They are injected into edge functions at runtime; never in frontend)

# Found at: supabase.com → your project → Settings → API → service_role key
# Only used by the Supabase CLI to deploy/test edge functions locally
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------ Plaid (edge functions only — NEVER in frontend) ----
# Found at: dashboard.plaid.com → Team Settings → Keys
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-sandbox-secret
# Options: sandbox | development | production
PLAID_ENV=sandbox
